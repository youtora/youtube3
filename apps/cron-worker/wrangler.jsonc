{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "youtube4-cron",
  "main": "src/index.js",
  "compatibility_date": "2026-04-23",
  "keep_vars": true,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1
    }
  },
  "triggers": {
    "crons": ["*/3 * * * *"]
  }
}
